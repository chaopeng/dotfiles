# Dank color generation
theme = Catppuccin Macchiato

command = fish

# Font Configuration
font-family = FiraCode Nerd Font Mono
font-style = Reg
font-size = 11

# Window Configuration
window-decoration = false
window-padding-x = 12
window-padding-y = 12
background-opacity = 0.8
background-blur-radius = 32

# Cursor Configuration
cursor-style = block
cursor-style-blink = true

# Scrollback
scrollback-limit = 20000

# Terminal features
mouse-hide-while-typing = true
copy-on-select = true
confirm-close-surface = false

# Disable annoying copied to clipboard
app-notifications = no-clipboard-copy,no-config-reload

# Material 3 UI elements
unfocused-split-opacity = 0.7
unfocused-split-fill = #44464f

# Tab configuration
gtk-titlebar = false

# Shell integration
shell-integration = fish
shell-integration-features = cursor,sudo,title,no-cursor,ssh-env,ssh-terminfo

# Rando stuff
gtk-single-instance = true

# Key bindings for common actions
keybind = ctrl+v=paste_from_clipboard
keybind = ctrl+shift+n=new_window
keybind = ctrl+shift+t=new_tab
keybind = ctrl+plus=increase_font_size:1
keybind = ctrl+minus=decrease_font_size:1
keybind = ctrl+zero=reset_font_size

# split
keybind = ctrl+shift+o=unbind
keybind = ctrl+shift+e=unbind
keybind = ctrl+shift+l=new_split:right
keybind = ctrl+shift+-=new_split:down

# jump to
keybind = ctrl+shift+page_up=unbind
keybind = ctrl+shift+page_down=unbind
keybind = ctrl+up=jump_to_prompt:-1
keybind = ctrl+down=jump_to_prompt:1

# clear
keybind = ctrl+k=clear_screen

# select and scrollback
keybind = ctrl+shift+a=unbind
keybind = ctrl+a=select_all
keybind = ctrl+shift+s=write_scrollback_file:open
keybind = shift+enter=text:\x1b\r
